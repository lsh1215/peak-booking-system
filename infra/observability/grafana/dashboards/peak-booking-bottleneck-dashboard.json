        {"expr": "system_cpu_usage{application=\"$application\"}", "legendFormat": "system cpu", "refId": "C"}
      ],
      "title": "JVM Threads / CPU",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
