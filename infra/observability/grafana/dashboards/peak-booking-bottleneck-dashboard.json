  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 0},
      "id": 1,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$application\",uri=~\"/api/v1/bookings|/api/v1/checkout/.*\"}[$__rate_interval])) by (uri, status)",
          "legendFormat": "{{uri}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Endpoint/Status",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ms"}, "overrides": []},
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"$application\",uri=~\"/api/v1/bookings|/api/v1/checkout/.*\"}[$__rate_interval])) by (le, uri)) * 1000",
          "legendFormat": "p95 {{uri}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"$application\",uri=~\"/api/v1/bookings|/api/v1/checkout/.*\"}[$__rate_interval])) by (le, uri)) * 1000",
          "legendFormat": "p99 {{uri}}",
          "refId": "B"
        }
      ],
      "title": "Request Latency",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []},
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$application\",status=~\"5..\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_requests_seconds_count{application=\"$application\"}[$__rate_interval])), 1)",
          "legendFormat": "5xx ratio",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$application\",status=~\"429\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_requests_seconds_count{application=\"$application\"}[$__rate_interval])), 1)",
          "legendFormat": "429 ratio",
          "refId": "B"
        }
      ],
      "title": "Failure / Shedding Ratio",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 7},
      "id": 4,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"expr": "hikaricp_connections_active{application=\"$application\"}", "legendFormat": "active", "refId": "A"},
        {"expr": "hikaricp_connections_idle{application=\"$application\"}", "legendFormat": "idle", "refId": "B"},
        {"expr": "hikaricp_connections_pending{application=\"$application\"}", "legendFormat": "pending", "refId": "C"},
        {"expr": "hikaricp_connections_max{application=\"$application\"}", "legendFormat": "max", "refId": "D"}
      ],
      "title": "Hikari Pool Pressure",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 7},
      "id": 5,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"expr": "sum(jvm_memory_used_bytes{application=\"$application\"}) by (area)", "legendFormat": "{{area}} used", "refId": "A"},
        {"expr": "sum(jvm_memory_committed_bytes{application=\"$application\"}) by (area)", "legendFormat": "{{area}} committed", "refId": "B"}
      ],
      "title": "JVM Memory",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 7},
      "id": 6,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}},
