      "id": 5,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total[$__rate_interval]) / clamp_min(rate(redis_keyspace_hits_total[$__rate_interval]) + rate(redis_keyspace_misses_total[$__rate_interval]), 1)",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ],
      "title": "Keyspace Hit Ratio",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 7},
      "id": 6,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"expr": "rate(redis_evicted_keys_total[$__rate_interval])", "legendFormat": "evicted keys/s", "refId": "A"},
        {"expr": "rate(redis_expired_keys_total[$__rate_interval])", "legendFormat": "expired keys/s", "refId": "B"}
      ],
      "title": "Eviction / Expiration",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 7},
      "id": 7,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"expr": "redis_db_keys", "legendFormat": "{{db}} keys", "refId": "A"},
