      "id": 2,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "rate(redis_commands_processed_total[$__rate_interval])", "legendFormat": "commands/s", "refId": "A"}],
      "title": "Command Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
